# ============================================
# AI Powered Sites - Environment Configuration
# ============================================
# Copy this file to .env and fill in your values
# All keys marked CHANGE_ME must be updated before deployment

# =====================
# Domain & Site
# =====================
DOMAIN=aipoweredsites.com
SITE_URL=https://aipoweredsites.com

# =====================
# Database (PostgreSQL)
# =====================
POSTGRES_USER=aips
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=aipoweredsites

# =====================
# Admin Authentication
# =====================
ADMIN_EMAIL=anthonyjacksonverizon@gmail.com
ADMIN_PASSWORD=CHANGE_ME

# Session encryption secret (generate with: openssl rand -hex 32)
SESSION_SECRET=CHANGE_ME

# =====================
# Stripe (Payments)
# =====================
STRIPE_SECRET_KEY=CHANGE_ME
STRIPE_PUBLISHABLE_KEY=CHANGE_ME
STRIPE_WEBHOOK_SECRET=CHANGE_ME

# =====================
# Resend (Email)
# =====================
RESEND_API_KEY=CHANGE_ME
RESEND_AUDIENCE_ID=

# =====================
# Push Notifications (VAPID)
# =====================
VAPID_PUBLIC_KEY=CHANGE_ME
VAPID_PRIVATE_KEY=CHANGE_ME
VAPID_SUBJECT=mailto:hello@aipoweredsites.com

# =====================
# OpenAI (AI Audit Reports & Content Creator)
# =====================
OPENAI_API_KEY=CHANGE_ME

# =====================
# GitHub (Git Backup & Deployments)
# =====================
GITHUB_CLIENT_ID=CHANGE_ME
GITHUB_CLIENT_SECRET=CHANGE_ME

# =====================
# Deployment Platforms
# =====================
NETLIFY_API_TOKEN=
VERCEL_API_TOKEN=
RAILWAY_API_TOKEN=

# =====================
# Linode API (Server Provisioning & DNS)
# =====================
LINODE_API_KEY=CHANGE_ME

# =====================
# Notion API (Knowledge Base Sync)
# =====================
NOTION_API_KEY=

# =====================
# Twilio (SMS Messaging)
# =====================
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
